# ============================================================
# Backend Environment Variables — EXAMPLE TEMPLATE
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env to version control.
# ============================================================

# Server Configuration
SERVER_PORT=8080

# Database Configuration (individual fields)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=questionnaire_db

# Optional: Direct database URL (overrides individual DB_* variables above)
# DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/questionnaire_db?sslmode=disable

# App Environment
APP_ENV=development
